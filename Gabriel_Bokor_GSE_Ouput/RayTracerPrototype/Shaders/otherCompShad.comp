#pragma optionNV(unroll all)
void main()
{
	switch(bufferInstance.sceneChoice)
	{
		case 0:
			InitialiseObjects1();
			break;
		case 1:
			InitialiseObjects2();
			break;
		default:
	}

	ivec2 pPos = ivec2(gl_GlobalInvocationID.xy);
	vec2 pCoord = vec2(0);
	vec2 dims = imageSize(u_Texture);
	vec3 shade = vec3(0,0,0);
	vec4 pixel = vec4(0,0,0,1);
	float fov = 90.0;

	vec2 m_output = vec2(0);
	vec3 direction = vec3(0);
	
		for (float i = 0; i < AASamples; i++)
		{
			pCoord.x = float(pPos.x) + (i / AASamples);
			pCoord.y = float(pPos.y) + (i / AASamples);

			m_output.x = camMapping(pCoord.x, 0, dims.x, -1, 1);
			m_output.y = camMapping(pCoord.y, 0, dims.y, -1, 1);

			vec4 nearPlane = vec4(m_output.x, m_output.y, -1, 1);
			vec4 farPlane = vec4(m_output.x, m_output.y,  1, 1);

			vec4 tfNear = bufferInstance.TransformMat * nearPlane;
			vec4 tfFar = bufferInstance.TransformMat * farPlane;

			vec3 nearProjection = vec3(tfNear.x, tfNear.y, tfNear.z) / tfNear.w;
			vec3 farProjection = vec3(tfFar.x, tfFar.y, tfFar.z) / tfFar.w;

			direction = farProjection - nearProjection;

			shade += vec3(traceRay(nearProjection, normalize(direction)));
		}

		shade /= AASamples;

	pixel = vec4(shade, 1.0);
	imageStore(u_Texture, ivec2(gl_GlobalInvocationID.xy), pixel);
}